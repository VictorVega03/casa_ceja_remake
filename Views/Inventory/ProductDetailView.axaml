<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Inventory"
        x:Class="CasaCejaRemake.Views.Inventory.ProductDetailView"
        x:DataType="vm:ProductDetailViewModel"
        Title="Detalles del Producto"
        Width="500" Height="480"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#1C1C1C">
    
    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#BDBDBD" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Margin" Value="0,0,0,15" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" Padding="20">
            <TextBlock Text="Detalles del Producto" FontSize="20" FontWeight="Bold" Foreground="White" />
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CÓDIGO DE BARRAS" Classes="label" />
                        <TextBlock Text="{Binding Product.Barcode}" Classes="value" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="NOMBRE" Classes="label" />
                        <TextBlock Text="{Binding Product.Name}" Classes="value" />
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CATEGORÍA" Classes="label" />
                        <TextBlock Text="{Binding Product.CategoryName}" Classes="value" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="UNIDAD" Classes="label" />
                        <TextBlock Text="{Binding Product.UnitName}" Classes="value" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="PRESENTACIÓN" Classes="label" />
                <TextBlock Text="{Binding Product.Presentation}" Classes="value" />

                <Separator Background="#3A3A3A" Margin="0,5,0,15" />

                <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PRECIO PÚBLICO" Classes="label" />
                        <TextBlock Text="{Binding Product.PriceRetail, StringFormat={}{0:C}}" Classes="value" FontWeight="Bold" Foreground="#4CAF50" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="PRECIO MAYOREO" Classes="label" />
                        <TextBlock Text="{Binding Product.PriceWholesale, StringFormat={}{0:C}}" Classes="value" />
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PRECIO ESPECIAL" Classes="label" />
                        <TextBlock Text="{Binding Product.PriceSpecial, StringFormat={}{0:C}}" Classes="value" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="PRECIO DISTRIBUIDOR" Classes="label" />
                        <TextBlock Text="{Binding Product.PriceDealer, StringFormat={}{0:C}}" Classes="value" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="CANTIDAD MAYOREO" Classes="label" />
                <TextBlock Text="{Binding Product.WholesaleQuantity}" Classes="value" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0" Padding="20">
            <Button Command="{Binding CloseCommand}"
                    Background="#1565C0" Foreground="White"
                    Padding="30,10" CornerRadius="4" FontWeight="Bold"
                    HorizontalAlignment="Right"
                    ToolTip.Tip="Cerrar (Esc)">
                <TextBlock Text="Cerrar" />
            </Button>
        </Border>
    </Grid>
</Window>
