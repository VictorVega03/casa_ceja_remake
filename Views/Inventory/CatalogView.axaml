<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Inventory"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="CasaCejaRemake.Views.Inventory.CatalogView"
        x:DataType="vm:CatalogViewModel"
        Title="Casa Ceja - Catálogo de Productos"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <!-- Estilos para TextBox en modo oscuro -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#1565C0" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Estilos para ComboBox en modo oscuro -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
        </Style>
        <!-- Estilos de DataGrid -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="RowBackground" Value="#252525" />
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#3A3A3A" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== HEADER Y HERRAMIENTAS ==================== -->
        <Border Grid.Row="0"
                Background="#2D2D2D"
                BorderBrush="#3A3A3A"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Command="{Binding GoBackCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="Volver al Menú Principal (Esc)">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="←" FontSize="14" Foreground="#1E88E5" VerticalAlignment="Center"/>
                            <TextBlock Text="Catálogo" FontSize="15" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Border Width="1" Height="24" Background="#4A4A4A" VerticalAlignment="Center" Margin="2,0"/>

                    <TextBox Text="{Binding SearchTerm}"
                             Width="220"
                             Watermark="Buscar por código o nombre..."
                             VerticalAlignment="Center">
                        <TextBox.KeyBindings>
                            <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}" />
                        </TextBox.KeyBindings>
                    </TextBox>

                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedValue="{Binding SelectedCategoryId}"
                              SelectedValueBinding="{Binding Id}"
                              Width="155"
                              VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox ItemsSource="{Binding Units}"
                              SelectedValue="{Binding SelectedUnitId}"
                              SelectedValueBinding="{Binding Id}"
                              Width="115"
                              VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Command="{Binding SearchCommand}"
                            Background="#1565C0"
                            Foreground="White"
                            Padding="10,5"
                            CornerRadius="4"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Buscar (F5)">
                        <TextBlock Text="Buscar" FontSize="13"/>
                    </Button>

                    <Button Command="{Binding ClearSearchCommand}"
                            Background="#424242"
                            Foreground="White"
                            Padding="10,5"
                            CornerRadius="4"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Limpiar (F4)">
                        <TextBlock Text="Limpiar" FontSize="13"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding CreateProductCommand}"
                            Background="#2E7D32"
                            Foreground="White"
                            Padding="12,7"
                            CornerRadius="4"
                            FontWeight="Bold"
                            ToolTip.Tip="Atajo: F2">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="+" FontSize="14" />
                            <TextBlock Text="Nuevo Producto (F2)" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== DATAGRID ==================== -->
        <Border Grid.Row="1" Margin="12" Background="#252525" CornerRadius="8" BorderBrush="#3A3A3A" BorderThickness="1" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding SearchResults}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#3A3A3A">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CÓDIGO" Binding="{Binding Barcode}" Width="150" />
                    <DataGridTextColumn Header="NOMBRE" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="CATEGORÍA" Binding="{Binding CategoryName}" Width="150" />
                    <DataGridTextColumn Header="MEDIDA" Binding="{Binding UnitName}" Width="150" />
                    <DataGridTextColumn Header="PRECIO VTA" Binding="{Binding PriceRetail, StringFormat={}{0:C}}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ==================== Paginación y Estado ==================== -->
        <Border Grid.Row="2" Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#BDBDBD" VerticalAlignment="Center" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            Background="#424242"
                            Foreground="White"
                            Padding="12,5"
                            CornerRadius="4">
                        <TextBlock Text="Anterior" />
                    </Button>

                    <Border Background="#1E1E1E" CornerRadius="4" Padding="15,5">
                        <TextBlock Text="{Binding PaginationInfo}" Foreground="#E0E0E0" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Border>

                    <Button Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}"
                            Background="#424242"
                            Foreground="White"
                            Padding="12,5"
                            CornerRadius="4">
                        <TextBlock Text="Siguiente" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
