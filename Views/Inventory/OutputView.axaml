<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Inventory"
        xmlns:helpers="using:CasaCejaRemake.Helpers"
        x:Class="CasaCejaRemake.Views.Inventory.OutputView"
        x:DataType="vm:OutputsViewModel"
        x:CompileBindings="False"
        Title="Salida / Traspaso de Mercancía"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#141414">

    <Window.Resources>
        <helpers:DecimalInputConverter x:Key="DecimalInputConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#42A5F5"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.action-save">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="22,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-save:pointerover">
            <Setter Property="Background" Value="#388E3C"/>
        </Style>
        <Style Selector="Button.action-save:disabled">
            <Setter Property="Background" Value="#1B3A1D"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style Selector="Button.action-cancel">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#BDBDBD"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-cancel:pointerover">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="#2A2A2A"/>
        </Style>
        <Style Selector="Button.remove-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E53935"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.remove-btn:pointerover">
            <Setter Property="Background" Value="#2A1010"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#252525"/>
            <Setter Property="RowHeight" Value="40"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Classes="icon-btn" Command="{Binding CancelCommand}" ToolTip.Tip="Cancelar (Esc)" CornerRadius="4">
                        <TextBlock Text="←" FontSize="16" Foreground="#42A5F5" FontWeight="Bold"/>
                    </Button>
                    <Border Width="4" Height="20" CornerRadius="2" Background="#42A5F5"/>
                    <TextBlock Text="SALIDA / TRASPASO DE MERCANCÍA" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#0D2233" CornerRadius="4" Padding="8,3" VerticalAlignment="Center"
                            IsVisible="{Binding HasLines}">
                        <TextBlock Text="{Binding Lines.Count, StringFormat='{}{0} productos'}"
                                   FontSize="11" FontWeight="Bold" Foreground="#42A5F5"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="SUCURSAL ORIGEN" Classes="label"/>
                        <TextBlock Text="{Binding BranchName}" FontSize="13" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="TOTAL SALIDA" Classes="label"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C}}"
                                   FontSize="15" FontWeight="Bold" Foreground="#4CAF50"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="320,*">

            <!-- ─── LEFT: Formulario ─── -->
            <Border Grid.Column="0" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0" Padding="20,16">
                <StackPanel Spacing="14">

                    <TextBlock Text="DATOS DE LA SALIDA" FontSize="11" FontWeight="Bold"
                               Foreground="#42A5F5" LetterSpacing="1" Margin="0,0,0,4"/>

                    <!-- Sucursal destino -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="SUCURSAL DESTINO" Classes="label"/>
                        <ComboBox ItemsSource="{Binding Branches}"
                                  SelectedItem="{Binding SelectedDestination}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBlock Text="Sin otras sucursales disponibles"
                                   FontSize="12" Foreground="#666"
                                   IsVisible="{Binding Branches.Count, Converter={x:Static ObjectConverters.IsNull}}"/>
                    </StackPanel>

                    <!-- Fecha -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="FECHA DE SALIDA" Classes="label"/>
                        <DatePicker SelectedDate="{Binding OutputDate}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Notas -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="NOTAS / OBSERVACIONES" Classes="label"/>
                        <TextBox Text="{Binding Notes}"
                                 Watermark="Observaciones opcionales..."
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="120"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <Border Height="1" Background="#2A2A2A" Margin="0,6"/>

                    <!-- Resumen -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="RESUMEN" FontSize="11" FontWeight="Bold" Foreground="#888" LetterSpacing="1"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Líneas de producto:" FontSize="12" Foreground="#999"/>
                            <TextBlock Grid.Column="1" Text="{Binding Lines.Count}" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Total de la salida:" FontSize="12" Foreground="#999"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:C}}"
                                       FontSize="13" Foreground="#4CAF50" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>

                    <!-- Aviso de estado -->
                    <Border Background="#1A1200" BorderBrush="#4A3800" BorderThickness="1" CornerRadius="6" Padding="10,8">
                        <StackPanel Spacing="4">
                            <TextBlock Text="⚠ Estado: PENDIENTE" FontSize="11" FontWeight="Bold" Foreground="#FFC107"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888"
                                       Text="La sucursal destino deberá confirmar la recepción para que su inventario se actualice."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ─── RIGHT: Productos ─── -->
            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">

                <!-- Búsqueda de productos -->
                <Border Grid.Row="0" Background="#1A1A1A" Padding="18,12" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="BUSCAR Y AGREGAR PRODUCTO" FontSize="11" FontWeight="Bold"
                                   Foreground="#42A5F5" LetterSpacing="1"/>
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBox Grid.Column="0"
                                     x:Name="SearchBox"
                                     Text="{Binding SearchTerm}"
                                     Watermark="Escanea el código de barras o escribe el nombre del producto + Enter..."
                                     KeyDown="OnSearchBoxKeyDown"/>
                            <Button Grid.Column="1"
                                    Command="{Binding SearchProductCommand}"
                                    Margin="10,0,0,0"
                                    Background="#FF9800" Foreground="White"
                                    Padding="16,8" CornerRadius="6"
                                    FontWeight="SemiBold" Cursor="Hand" FontSize="13">
                                Agregar
                            </Button>
                            <Button Grid.Column="2"
                                    Command="{Binding OpenCatalogCommand}"
                                    Margin="8,0,0,0"
                                    Background="#2F5D8A" Foreground="White"
                                    Padding="14,8" CornerRadius="6"
                                    FontWeight="SemiBold" Cursor="Hand" FontSize="13">
                                Catálogo (F3)
                            </Button>
                        </Grid>
                        <TextBlock Text="{Binding SearchError}"
                                   IsVisible="{Binding SearchError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="13" Foreground="#EF5350" Margin="4,0"/>
                    </StackPanel>
                </Border>

                <!-- Estado vacío -->
                <Border Grid.Row="1" IsVisible="{Binding !HasLines}" Background="#141414" Padding="0,40">
                    <StackPanel HorizontalAlignment="Center" Spacing="10">
                        <TextBlock Text="📤" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="Aún no hay productos en esta salida"
                                   FontSize="14" Foreground="#555" HorizontalAlignment="Center"/>
                        <TextBlock Text="Usa el buscador de arriba para agregar productos"
                                   FontSize="12" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- DataGrid de productos -->
                <DataGrid Grid.Row="2"
                          x:Name="LinesGrid"
                          ItemsSource="{Binding Lines}"
                          SelectedItem="{Binding SelectedLine}"
                          AutoGenerateColumns="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          IsVisible="{Binding HasLines}">
                    <DataGrid.Columns>

                        <!-- Código -->
                        <DataGridTextColumn Header="CÓDIGO" Binding="{Binding Barcode}"
                                            Width="110" IsReadOnly="True"/>

                        <!-- Nombre -->
                        <DataGridTextColumn Header="PRODUCTO" Binding="{Binding ProductName}"
                                            Width="*" IsReadOnly="True"/>

                        <!-- Stock disponible -->
                        <DataGridTextColumn Header="ACTUAL" Binding="{Binding CurrentStock}"
                                            Width="90" IsReadOnly="True"/>

                        <!-- Cantidad (editable con +/-) -->
                        <DataGridTemplateColumn Header="CANTIDAD" Width="115">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Button Classes="icon-btn" CornerRadius="4"
                                                Command="{Binding DataContext.DecrementQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="−" FontSize="16" Foreground="#BDBDBD"/>
                                        </Button>
                                        <TextBox Text="{Binding Quantity, Mode=OneWay}"
                                                 Width="46"
                                                 Padding="0"
                                                 FontSize="15"
                                                 FontWeight="SemiBold"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 Background="#2A2A2A"
                                                 BorderBrush="#3A3A3A"
                                                 TextChanged="OnQuantityTextChanged"
                                                 LostFocus="OnQuantityLostFocus"/>
                                        <Button Classes="icon-btn" CornerRadius="4"
                                                Command="{Binding DataContext.IncrementQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="+" FontSize="16" Foreground="#BDBDBD"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Costo unitario (editable) -->
                        <DataGridTextColumn Header="COSTO UNIT."
                                            Binding="{Binding UnitCost, Converter={StaticResource DecimalInputConverter}}"
                                            Width="110"
                                            IsReadOnly="False"/>

                        <!-- Total línea (readonly) -->
                        <DataGridTextColumn Header="TOTAL LÍNEA" Binding="{Binding LineTotal, StringFormat={}{0:C}}"
                                            Width="110" IsReadOnly="True"/>

                        <!-- Eliminar -->
                        <DataGridTemplateColumn Header="" Width="48" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Classes="remove-btn"
                                            Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Center"
                                            ToolTip.Tip="Quitar producto">
                                        <TextBlock Text="✕" FontSize="15"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="2" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Esc: Salir   |   F3: Catálogo   |   Flechas ←/→: Ajustar cantidad"
                           FontSize="11" Foreground="#444" VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        Classes="action-save"
                        Command="{Binding SaveOutputCommand}"
                        IsEnabled="{Binding !IsSaving}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Guardando..." IsVisible="{Binding IsSaving}" VerticalAlignment="Center"/>
                        <TextBlock Text="Guardar Salida (F5)" IsVisible="{Binding !IsSaving}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
