<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Inventory"
        xmlns:helpers="using:CasaCejaRemake.Helpers"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="CasaCejaRemake.Views.Inventory.InventoryMainView"
        x:DataType="vm:InventoryMainViewModel"
        Title="Casa Ceja - Inventario"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C">

    <Window.Resources>
        <helpers:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ==================== HEADER ==================== -->
        <Border Grid.Row="0"
            Background="#2F5D8A"
            BorderBrush="#274E75"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Título e info de sesión -->
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="INVENTARIO"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#FFFFFF" />
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <Path Fill="#BBDEFB" Width="11" Height="11" Stretch="Uniform" VerticalAlignment="Center"
                              Data="M12,2C8.13,2,5,5.13,5,9c0,5.25,7,13,7,13s7-7.75,7-13C19,5.13,15.87,2,12,2z M12,11.5c-1.38,0-2.5-1.12-2.5-2.5s1.12-2.5,2.5-2.5s2.5,1.12,2.5,2.5S13.38,11.5,12,11.5z" />
                        <TextBlock Text="{Binding BranchName}"
                                   FontSize="13"
                                   Foreground="#E3F2FD"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="·"
                                   FontSize="13"
                                   Foreground="#BBDEFB"
                                   VerticalAlignment="Center"
                                   Margin="2,0" />
                        <Path Fill="#BBDEFB" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"
                              Data="M12,12c2.21,0,4-1.79,4-4s-1.79-4-4-4S8,5.79,8,8,9.79,12,12,12z M12,14c-2.67,0-8,1.34-8,4v2h16v-2C20,15.34,14.67,14,12,14z" />
                        <TextBlock Text="{Binding UserName}"
                                   FontSize="13"
                                   Foreground="#E3F2FD"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Botones de acción -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                    <!-- Reintentar (solo visible si offline) -->
                    <Button Command="{Binding CheckConnectivityCommand}"
                            IsVisible="{Binding !IsOnline}"
                            FontSize="12"
                            Height="34"
                            Padding="14,0"
                            Background="#274E75"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            ToolTip.Tip="Verificar conexión al servidor">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Path Fill="White" Width="12" Height="12" Stretch="Uniform"
                                  Data="M17.65,6.35C16.2,4.9,14.21,4,12,4c-4.42,0-7.99,3.58-7.99,8s3.57,8,7.99,8c3.73,0,6.84-2.55,7.73-6h-2.08C16.78,16.21,14.61,18,12,18c-3.31,0-6-2.69-6-6s2.69-6,6-6c1.66,0,3.14,0.69,4.22,1.78L13,11h7V4L17.65,6.35z" />
                            <TextBlock Text="Reintentar conexión" VerticalAlignment="Center" />
                        </StackPanel>
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#1F3F5E" />
                            </Style>
                        </Button.Styles>
                    </Button>

                    <!-- Salir de Inventario -->
                    <Button Command="{Binding ExitCommand}"
                            FontSize="13"
                            Height="36"
                            Padding="15,0"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            ToolTip.Tip="Salir de Inventario">
                        <TextBlock Text="Salir de Inventario" VerticalAlignment="Center" FontWeight="Bold"/>
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Background" Value="#B71C1C" />
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== BANNER OFFLINE ==================== -->
        <Border Grid.Row="1"
                Background="#6E2A2A"
                Padding="16,7"
                IsVisible="{Binding !IsOnline}">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <Path Fill="#E0B2B2" Width="15" Height="15" Stretch="Uniform"
                      Data="M1,21h22L12,2 1,21z M13,18h-2v-2h2v2z M13,14h-2v-4h2v4z" />
                <TextBlock Text="Sin conexión — Usando modo local. Algunas funciones pueden estar limitadas."
                           Foreground="#F3D5D5"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Banner online (aparece 3 segundos al reconectar) -->
        <Border Grid.Row="1"
                Background="#1B5E20"
                Padding="16,7"
                IsVisible="{Binding ShowOnlineBanner}">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <Path Fill="#A5D6A7" Width="15" Height="15" Stretch="Uniform"
                      Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M10,17l-5-5l1.41-1.41L10,14.17l7.59-7.59L19,8L10,17z" />
                <TextBlock Text="Conexión establecida con el servidor."
                           Foreground="#C8E6C9"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Banner verificando -->
        <Border Grid.Row="1"
                Background="#0D47A1"
                Padding="10,6"
                IsVisible="{Binding IsCheckingConnection}">
            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="90" Height="3" Foreground="#90CAF9" />
                <TextBlock Text="Verificando conexión con el servidor..."
                           Foreground="#90CAF9"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ==================== CARDS ==================== -->
        <Grid Grid.Row="2" Margin="60,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== CARD 1: ENTRADA ===== -->
            <Button Grid.Row="0" Grid.Column="0"
                    Command="{Binding OpenEntriesCommand}"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    BorderBrush="#BBBBBB" BorderThickness="1"
                    CornerRadius="10" Padding="20,22">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="Background" Value="#D8D8D8" />
                    </Style>
                    <Style Selector="Button[IsEnabled=false]">
                        <Setter Property="Background" Value="#D8D8D8" />
                        <Setter Property="Opacity" Value="0.6" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </Style>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#C4C4C4" />
                    </Style>
                    <Style Selector="Button[IsEnabled=true]:pointerover">
                        <Setter Property="Background" Value="#C4C4C4" />
                        <Setter Property="BorderBrush" Value="#43A047" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>
                </Button.Styles>
                <Button.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" OffsetX="0" OffsetY="3"/>
                </Button.Effect>
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#2E7D32" />
                        </Border.Background>
                        <TextBlock Text="📥" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="ENTRADA DE MERCANCÍA" FontSize="14" FontWeight="Bold"
                               Foreground="#212121" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock Text="Registrar productos recibidos desde bodega o proveedores" FontSize="12"
                               Foreground="#757575" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- ===== CARD 2: SALIDA / TRASPASO ===== -->
            <Button Grid.Row="0" Grid.Column="2"
                    Command="{Binding OpenOutputsCommand}"
                    IsEnabled="{Binding IsOnline}"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    BorderBrush="#BBBBBB" BorderThickness="1"
                    CornerRadius="10" Padding="20,22">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="Background" Value="#D8D8D8" />
                    </Style>
                    <Style Selector="Button[IsEnabled=false]">
                        <Setter Property="Background" Value="#D8D8D8" />
                        <Setter Property="Opacity" Value="0.6" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </Style>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#C4C4C4" />
                    </Style>
                    <Style Selector="Button[IsEnabled=true]:pointerover">
                        <Setter Property="Background" Value="#C4C4C4" />
                        <Setter Property="BorderBrush" Value="#E53935" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>
                </Button.Styles>
                <Button.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" OffsetX="0" OffsetY="3"/>
                </Button.Effect>
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#B71C1C" Opacity="{Binding IsOnline, Converter={StaticResource BoolToOpacityConverter}}" />
                        </Border.Background>
                        <Panel>
                            <TextBlock Text="📤" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding IsOnline}" />
                            <Path Fill="#9E9E9E" Width="30" Height="30" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  IsVisible="{Binding !IsOnline}"
                                  Data="M18,8h-1V6c0-2.76-2.24-5-5-5S7,3.24,7,6v2H6c-1.1,0-2,0.9-2,2v10c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V10C20,8.9,19.1,8,18,8z M12,17c-1.1,0-2-0.9-2-2s0.9-2,2-2s2,0.9,2,2S13.1,17,12,17z M15.1,8H8.9V6c0-1.71,1.39-3.1,3.1-3.1s3.1,1.39,3.1,3.1V8z" />
                        </Panel>
                    </Border>
                    <TextBlock Text="SALIDA DE MERCANCÍA" FontSize="14" FontWeight="Bold"
                               Foreground="#212121" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock Text="Enviar productos a otra sucursal" FontSize="12"
                               Foreground="#757575" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- ===== CARD 3: CONFIRMAR ENTRADA ===== -->
            <Button Grid.Row="0" Grid.Column="4"
                    Command="{Binding OpenConfirmEntryCommand}"
                    IsEnabled="{Binding IsOnline}"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    BorderBrush="#BBBBBB" BorderThickness="1"
                    CornerRadius="10" Padding="20,22">
                <Button.Styles>
                    <Style Selector="Button">
                        <Setter Property="Background" Value="#D8D8D8" />
                    </Style>
                    <Style Selector="Button[IsEnabled=false]">
                        <Setter Property="Background" Value="#D8D8D8" />
                        <Setter Property="Opacity" Value="0.6" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </Style>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#C4C4C4" />
                    </Style>
                    <Style Selector="Button[IsEnabled=true]:pointerover">
                        <Setter Property="Background" Value="#C4C4C4" />
                        <Setter Property="BorderBrush" Value="#00897B" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>
                </Button.Styles>
                <Button.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" OffsetX="0" OffsetY="3"/>
                </Button.Effect>
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="70" Height="70" CornerRadius="35" HorizontalAlignment="Center">
                        <Border.Background>
                            <SolidColorBrush Color="#00695C" Opacity="{Binding IsOnline, Converter={StaticResource BoolToOpacityConverter}}" />
                        </Border.Background>
                        <Panel>
                            <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding IsOnline}" />
                            <Path Fill="#9E9E9E" Width="30" Height="30" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  IsVisible="{Binding !IsOnline}"
                                  Data="M18,8h-1V6c0-2.76-2.24-5-5-5S7,3.24,7,6v2H6c-1.1,0-2,0.9-2,2v10c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V10C20,8.9,19.1,8,18,8z M12,17c-1.1,0-2-0.9-2-2s0.9-2,2-2s2,0.9,2,2S13.1,17,12,17z M15.1,8H8.9V6c0-1.71,1.39-3.1,3.1-3.1s3.1,1.39,3.1,3.1V8z" />
                        </Panel>
                    </Border>
                    <TextBlock Text="CONFIRMAR ENTRADA" FontSize="14" FontWeight="Bold"
                               Foreground="#212121" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock Text="Validar mercancía recibida" FontSize="12"
                               Foreground="#757575" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- ===== CARD 4: CATÁLOGO DE PRODUCTOS ===== -->
            <Button Grid.Row="2" Grid.Column="0"
                    Command="{Binding OpenCatalogCommand}"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    Background="#D8D8D8"
                    BorderBrush="#BBBBBB" BorderThickness="1"
                    CornerRadius="10" Padding="20,22">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#C4C4C4" />
                        <Setter Property="BorderBrush" Value="#1565C0" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#C4C4C4" />
                    </Style>
                </Button.Styles>
                <Button.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" OffsetX="0" OffsetY="3"/>
                </Button.Effect>
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="70" Height="70" Background="#1565C0" CornerRadius="35" HorizontalAlignment="Center">
                        <TextBlock Text="📋" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="CATÁLOGO DE PRODUCTOS" FontSize="14" FontWeight="Bold"
                               Foreground="#212121" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock Text="Consultar productos y Crear nuevos" FontSize="12"
                               Foreground="#757575" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- ===== CARD 5: CATEGORÍAS Y MEDIDAS ===== -->
            <Button Grid.Row="2" Grid.Column="2"
                    Command="{Binding OpenCategoriesCommand}"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    Background="#D8D8D8"
                    BorderBrush="#BBBBBB" BorderThickness="1"
                    CornerRadius="10" Padding="20,22">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#C4C4C4" />
                        <Setter Property="BorderBrush" Value="#7B1FA2" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#C4C4C4" />
                    </Style>
                </Button.Styles>
                <Button.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" OffsetX="0" OffsetY="3"/>
                </Button.Effect>
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="70" Height="70" Background="#6A1B9A" CornerRadius="35" HorizontalAlignment="Center">
                        <TextBlock Text="🏷️" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="CATEGORÍAS Y MEDIDAS" FontSize="14" FontWeight="Bold"
                               Foreground="#212121" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock Text="Agregar o modificar categorias y medidas" FontSize="12"
                               Foreground="#757575" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- ===== CARD 6: HISTORIAL ===== -->
            <Button Grid.Row="2" Grid.Column="4"
                    Command="{Binding OpenHistoryCommand}"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    Background="#D8D8D8"
                    BorderBrush="#BBBBBB" BorderThickness="1"
                    CornerRadius="10" Padding="20,22">
                <Button.Styles>
                    <Style Selector="Button:pointerover">
                        <Setter Property="Background" Value="#C4C4C4" />
                        <Setter Property="BorderBrush" Value="#546E7A" />
                        <Setter Property="BorderThickness" Value="2" />
                    </Style>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="#C4C4C4" />
                    </Style>
                </Button.Styles>
                <Button.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" OffsetX="0" OffsetY="3"/>
                </Button.Effect>
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Width="70" Height="70" Background="#37474F" CornerRadius="35" HorizontalAlignment="Center">
                        <TextBlock Text="📊" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="HISTORIAL" FontSize="14" FontWeight="Bold"
                               Foreground="#212121" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                    <TextBlock Text="Historial de entradas y salidas" FontSize="12"
                               Foreground="#757575" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
