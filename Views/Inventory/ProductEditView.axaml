<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Shared"
        x:Class="CasaCejaRemake.Views.Inventory.ProductEditView"
        x:DataType="vm:ProductFormViewModel"
        Title="{Binding Title}"
        Width="680" MinWidth="560"
        SizeToContent="Height"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#1C1C1C">

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#1565C0" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="Foreground" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#BDBDBD" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" IsEnabled="{Binding !IsSaving}">

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="0,0,0,1" Padding="20,14">
            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10" Margin="20,16">

                <!-- Código + Nombre -->
                <Grid ColumnDefinitions="*,16,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CÓDIGO DE BARRAS *" Classes="label" />
                        <TextBox Text="{Binding Barcode}" Watermark="Ej. 123456789"
                                 TextChanged="NoSpecialCharsTextBox_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="NOMBRE DEL PRODUCTO *" Classes="label" />
                        <TextBox Text="{Binding Name}" Watermark="Ej. Tornillo de pulgada"
                                 TextChanged="NoSpecialCharsTextBox_TextChanged" />
                    </StackPanel>
                </Grid>

                <!-- Categoría + Medida -->
                <Grid ColumnDefinitions="*,16,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CATEGORÍA *" Classes="label" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedValue="{Binding CategoryId}"
                                  SelectedValueBinding="{Binding Id}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="UNIDAD DE MEDIDA *" Classes="label" />
                        <ComboBox ItemsSource="{Binding Units}"
                                  SelectedValue="{Binding UnitId}"
                                  SelectedValueBinding="{Binding Id}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Presentación -->
                <StackPanel>
                    <TextBlock Text="PRESENTACIÓN" Classes="label" />
                    <TextBox Text="{Binding Presentation}" Watermark="Ej. Caja con 10pz"
                             TextChanged="NoSpecialCharsTextBox_TextChanged" />
                </StackPanel>

                <Separator Background="#3A3A3A" Margin="0,4" />

                <!-- Precios -->
                <TextBlock Text="PRECIOS DE VENTA" Foreground="White" FontWeight="Bold" FontSize="13" />

                <Grid ColumnDefinitions="*,16,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PRECIO AL PÚBLICO (MENUDEO) *" Classes="label" />
                        <TextBox Text="{Binding PriceRetail}" TextChanged="DecimalTextBox_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PRECIO MAYOREO" Classes="label" />
                        <TextBox Text="{Binding PriceWholesale}" TextChanged="DecimalTextBox_TextChanged" />
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,16,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CANTIDAD PARA MAYOREO" Classes="label" />
                        <TextBox Text="{Binding WholesaleQuantity}" TextChanged="IntTextBox_TextChanged" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="PRECIO ESPECIAL (MAYORISTAS)" Classes="label" />
                        <TextBox Text="{Binding PriceSpecial}" TextChanged="DecimalTextBox_TextChanged" />
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,16,*">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PRECIO DE DISTRIBUIDOR" Classes="label" />
                        <TextBox Text="{Binding PriceDealer}" TextChanged="DecimalTextBox_TextChanged" />
                    </StackPanel>
                </Grid>

                <!-- Estado -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="#EF5350"
                           FontWeight="SemiBold" TextWrapping="Wrap"
                           IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            </StackPanel>
        </ScrollViewer>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#2D2D2D" BorderBrush="#3A3A3A" BorderThickness="0,1,0,0" Padding="20,12">
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Command="{Binding CancelCommand}"
                        Background="#424242"
                        Foreground="White"
                        Padding="20,8"
                        CornerRadius="4"
                        ToolTip.Tip="Esc">
                    <TextBlock Text="Cancelar (Esc)" />
                </Button>
                <Button Command="{Binding SaveCommand}"
                        Background="#1565C0"
                        Foreground="White"
                        Padding="20,8"
                        CornerRadius="4"
                        FontWeight="Bold"
                        ToolTip.Tip="F3">
                    <TextBlock Text="Guardar Cambios (F3)" />
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>
