<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Inventory"
        xmlns:helpers="using:CasaCejaRemake.Helpers"
        x:Class="CasaCejaRemake.Views.Inventory.EntryView"
        x:DataType="vm:EntriesViewModel"
        x:CompileBindings="False"
        Title="Entrada de Mercancía"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#141414">

    <Window.Resources>
        <helpers:DecimalInputConverter x:Key="DecimalInputConverter" />
    </Window.Resources>

    <Window.Styles>
        <!-- Labels -->
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <!-- Input fields -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#FF9800"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- Buttons -->
        <Style Selector="Button.action-save">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="32,14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-save:pointerover">
            <Setter Property="Background" Value="#388E3C"/>
        </Style>
        <Style Selector="Button.action-save:disabled">
            <Setter Property="Background" Value="#1B3A1D"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style Selector="Button.action-cancel">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#BDBDBD"/>
            <Setter Property="Padding" Value="28,14"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action-cancel:pointerover">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Button.icon-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.icon-btn:pointerover">
            <Setter Property="Background" Value="#2A2A2A"/>
        </Style>
        <Style Selector="Button.remove-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E53935"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.remove-btn:pointerover">
            <Setter Property="Background" Value="#2A1010"/>
        </Style>
        <!-- DataGrid -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#252525"/>
            <Setter Property="RowHeight" Value="52"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="14,10"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Padding="28,18">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Button Classes="icon-btn" Command="{Binding CancelCommand}" ToolTip.Tip="Cancelar (Esc)" CornerRadius="4">
                        <TextBlock Text="←" FontSize="20" Foreground="#FF9800" FontWeight="Bold"/>
                    </Button>
                    <Border Width="5" Height="24" CornerRadius="2" Background="#FF9800"/>
                    <TextBlock Text="ENTRADA DE MERCANCÍA" FontSize="20" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#1B3A1D" CornerRadius="4" Padding="10,4" VerticalAlignment="Center"
                            IsVisible="{Binding HasLines}">
                        <TextBlock Text="{Binding Lines.Count, StringFormat='{}{0} productos'}"
                                   FontSize="12" FontWeight="Bold" Foreground="#4CAF50"/>
                    </Border>
                </StackPanel>

                <!-- Folio/sucursal info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="28" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="SUCURSAL" Classes="label"/>
                        <TextBlock Text="{Binding BranchName}" FontSize="15" Foreground="#E0E0E0" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="TOTAL ENTRADA" Classes="label"/>
                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C}}"
                                   FontSize="18" FontWeight="Bold" Foreground="#4CAF50"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="1" ColumnDefinitions="380,*">

            <!-- ─── LEFT: Formulario de encabezado ─── -->
            <Border Grid.Column="0" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="0,0,1,0" Padding="28,24">
                <StackPanel Spacing="20">

                    <TextBlock Text="DATOS DE LA ENTRADA" FontSize="12" FontWeight="Bold"
                               Foreground="#FF9800" LetterSpacing="1" Margin="0,0,0,6"/>

                    <!-- Proveedor -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="PROVEEDOR" Classes="label"/>
                        <ComboBox ItemsSource="{Binding Suppliers}"
                                  SelectedItem="{Binding SelectedSupplier}"
                                  HorizontalAlignment="Stretch">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Fecha -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="FECHA DE ENTRADA" Classes="label"/>
                        <DatePicker SelectedDate="{Binding EntryDate}" HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Notas -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="NOTAS / OBSERVACIONES" Classes="label"/>
                        <TextBox Text="{Binding Notes}"
                                 Watermark="Observaciones opcionales..."
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="120"
                                 VerticalContentAlignment="Top"/>
                    </StackPanel>

                    <!-- Separador -->
                    <Border Height="1" Background="#2A2A2A" Margin="0,6"/>

                    <!-- Resumen -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="RESUMEN" FontSize="12" FontWeight="Bold" Foreground="#888" LetterSpacing="1"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Líneas de producto:" FontSize="14" Foreground="#999"/>
                            <TextBlock Grid.Column="1" Text="{Binding Lines.Count}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Total de la entrada:" FontSize="14" Foreground="#999"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalAmount, StringFormat={}{0:C}}"
                                       FontSize="15" Foreground="#4CAF50" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ─── RIGHT: Productos ─── -->
            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">

                <!-- Búsqueda de productos -->
                <Border Grid.Row="0" Background="#1A1A1A" Padding="24,18" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="BUSCAR Y AGREGAR PRODUCTO" FontSize="12" FontWeight="Bold"
                                   Foreground="#FF9800" LetterSpacing="1"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     x:Name="SearchBox"
                                     Text="{Binding SearchTerm}"
                                     Watermark="Escanea el código de barras o escribe el nombre del producto + Enter..."
                                     KeyDown="OnSearchBoxKeyDown"/>
                            <Button Grid.Column="1"
                                    Command="{Binding SearchProductCommand}"
                                    Margin="12,0,0,0"
                                    Background="#FF9800" Foreground="White"
                                    Padding="22,10" CornerRadius="6"
                                    FontWeight="SemiBold" Cursor="Hand">
                                Agregar
                            </Button>
                        </Grid>
                        <!-- Error de búsqueda -->
                        <TextBlock Text="{Binding SearchError}"
                                   IsVisible="{Binding SearchError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="13" Foreground="#EF5350" Margin="4,0"/>
                    </StackPanel>
                </Border>

                <!-- Estado vacío -->
                <Border Grid.Row="1" IsVisible="{Binding !HasLines}" Background="#141414" Padding="0,60">
                    <StackPanel HorizontalAlignment="Center" Spacing="14">
                        <TextBlock Text="📦" FontSize="56" HorizontalAlignment="Center"/>
                        <TextBlock Text="Aún no hay productos en esta entrada"
                                   FontSize="17" Foreground="#555" HorizontalAlignment="Center"/>
                        <TextBlock Text="Usa el buscador de arriba para agregar productos"
                                   FontSize="14" Foreground="#444" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- DataGrid de productos -->
                <DataGrid Grid.Row="2"
                          x:Name="LinesGrid"
                          ItemsSource="{Binding Lines}"
                          SelectedItem="{Binding SelectedLine}"
                          AutoGenerateColumns="False"
                          CanUserReorderColumns="False"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="False"
                          IsReadOnly="False"
                          SelectionMode="Single"
                          IsVisible="{Binding HasLines}"
                          CellEditEnded="OnCellEditEnded">
                    <DataGrid.Columns>

                        <!-- Código -->
                        <DataGridTextColumn Header="CÓDIGO" Binding="{Binding Barcode}"
                                            Width="150" IsReadOnly="True"/>

                        <!-- Nombre -->
                        <DataGridTextColumn Header="PRODUCTO" Binding="{Binding ProductName}"
                                            Width="*" IsReadOnly="True"/>

                        <!-- Cantidad (editable) -->
                        <DataGridTemplateColumn Header="CANTIDAD" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Button Classes="icon-btn" CornerRadius="4"
                                                Command="{Binding DataContext.DecrementQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="−" FontSize="16" Foreground="#BDBDBD"/>
                                        </Button>
                                        <TextBlock Text="{Binding Quantity}" FontSize="16" FontWeight="SemiBold"
                                                   Foreground="White" VerticalAlignment="Center" Width="40"
                                                   TextAlignment="Center"/>
                                        <Button Classes="icon-btn" CornerRadius="4"
                                                Command="{Binding DataContext.IncrementQtyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <TextBlock Text="+" FontSize="16" Foreground="#BDBDBD"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Costo unitario (editable) -->
                        <DataGridTextColumn Header="COSTO UNIT." 
                                            Binding="{Binding UnitCost, Converter={StaticResource DecimalInputConverter}}"
                                            Width="150"/>

                        <!-- Total línea (readonly) -->
                        <DataGridTextColumn Header="TOTAL LÍNEA" Binding="{Binding LineTotal, StringFormat={}{0:C}}"
                                            Width="150" IsReadOnly="True"/>

                        <!-- Eliminar -->
                        <DataGridTemplateColumn Header="" Width="64" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Classes="remove-btn"
                                            Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            HorizontalAlignment="Center"
                                            ToolTip.Tip="Quitar producto">
                                        <TextBlock Text="✕" FontSize="15"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="2" Background="#1C1C1C" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="28,18">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Esc: Cancelar   |   Los costos unitarios son editables en la tabla"
                           FontSize="13" Foreground="#444" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14">
                    <Button Classes="action-cancel" Command="{Binding CancelCommand}">
                        Cancelar
                    </Button>
                    <Button Classes="action-save"
                            Command="{Binding SaveEntryCommand}"
                            IsEnabled="{Binding !IsSaving}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Guardando..." IsVisible="{Binding IsSaving}" VerticalAlignment="Center"/>
                            <TextBlock Text="Guardar Entrada (F5)" IsVisible="{Binding !IsSaving}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
