<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Shared"
        mc:Ignorable="d"
        d:DesignWidth="650" d:DesignHeight="700"
        x:Class="CasaCejaRemake.Views.Shared.PosTerminalConfigView"
        x:DataType="vm:PosTerminalConfigViewModel"
        Title="Configuración del Terminal POS"
        Width="550"
        SizeToContent="Height"
        MaxHeight="650"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Focusable="True"
        Background="#1E1E1E">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#B0B0B0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,10,0,5" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="Foreground" Value="#4FC3F7" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,24,0,12" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="ComboBox:pointerover">
            <Setter Property="Background" Value="#353535" />
            <Setter Property="BorderBrush" Value="#4FC3F7" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#404040" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="TextBox:pointerover">
            <Setter Property="BorderBrush" Value="#4FC3F7" />
        </Style>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style Selector="Button.refresh">
            <Setter Property="Background" Value="#FF9800" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.refresh:pointerover">
            <Setter Property="Background" Value="#FFA726" />
        </Style>
        <Style Selector="Button.cancel">
            <Setter Property="Background" Value="#404040" />
            <Setter Property="Foreground" Value="White" />
        </Style>
        <Style Selector="Button.cancel:pointerover">
            <Setter Property="Background" Value="#505050" />
        </Style>
        <Style Selector="Button.save">
            <Setter Property="Background" Value="#4CAF50" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="Button.save:pointerover">
            <Setter Property="Background" Value="#66BB6A" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Background="#252525" Padding="20,16">
            <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0"
                        Width="40" Height="40"
                        Background="#2196F3"
                        CornerRadius="8"
                        Margin="0,0,12,0">
                    <TextBlock Text="🖥️" 
                               FontSize="20" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Configuración del Terminal POS"
                               FontSize="20" 
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Configurar tickets y parámetros de este terminal"
                               FontSize="11"
                               Foreground="#888888"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== CONTENT ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,16" Spacing="12">

                <!-- ========== IDENTIFICACIÓN DEL TERMINAL ========== -->
                <Border Background="#252525" 
                        CornerRadius="6" 
                        Padding="16,12"
                        BorderBrush="#404040"
                        BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🏷️" FontSize="18" VerticalAlignment="Center" />
                            <TextBlock Classes="section-title" 
                                       Text="Identificación del Terminal"
                                       Margin="0" />
                        </StackPanel>

                        <TextBlock Classes="label" Text="ID de Terminal:" />
                        <TextBox Text="{Binding TerminalId}"
                                 IsReadOnly="{Binding IsReadOnlyForCajero}"
                                 Watermark="Ej: CAJA-01" />

                        <TextBlock Classes="label" Text="Nombre de Terminal (opcional):" />
                        <TextBox Text="{Binding TerminalName}"
                                 Watermark="Ej: Caja Principal" />
                    </StackPanel>
                </Border>

                <!-- ========== PARÁMETROS DEL TICKET ========== -->
                <Border Background="#252525" 
                        CornerRadius="6" 
                        Padding="16,12"
                        BorderBrush="{Binding TicketSettingsBorderColor}"
                        BorderThickness="1"
                        Margin="0,8,0,0">
                    <StackPanel>
                        <!-- Header con botón desbloquear -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="🎫" FontSize="18" VerticalAlignment="Center" />
                                <TextBlock Classes="section-title" 
                                           Text="Parámetros del Ticket"
                                           Margin="0" />
                            </StackPanel>

                            <!-- Indicador de estado de bloqueo -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding TicketStatusText}"
                                       Foreground="{Binding TicketStatusColor}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0" />

                            <Button Grid.Column="2"
                                    Content="{Binding TicketLockButtonText}"
                                    Command="{Binding ToggleTicketLockCommand}"
                                    VerticalAlignment="Center"
                                    Height="32"
                                    Padding="12,0"
                                    FontSize="12"
                                    CornerRadius="6"
                                    Background="{Binding TicketButtonBackground}"
                                    Foreground="White" />
                        </Grid>

                        <!-- Banner de bloqueo (solo visible para cajeros sin desbloquear) -->
                        <Border Background="#1A2A3A"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,10,0,0"
                                BorderBrush="#2196F3"
                                BorderThickness="1"
                                IsVisible="{Binding IsTicketSettingsLocked}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🔒" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="Estos parámetros requieren autorización de administrador para modificarse."
                                           Foreground="#90CAF9"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!-- Campos del ticket (deshabilitados si están bloqueados) -->
                        <StackPanel IsEnabled="{Binding TicketSettingsUnlocked}">
                            <TextBlock Classes="label" Text="Mensaje al pie del ticket:" />
                            <TextBox Text="{Binding TicketFooter}"
                                     Watermark="Ej: ¡Gracias por su compra!" />

                            <Grid ColumnDefinitions="*,16,*" Margin="0,8,0,0">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Classes="label" Text="Tamaño de fuente (T. Carta):" />
                                    <ComboBox ItemsSource="{Binding FontSizeOptions}"
                                              SelectedItem="{Binding SelectedFontSize}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Classes="label" Text="Ancho de línea -T. Carta- (chars):" />
                                    <ComboBox ItemsSource="{Binding TicketLineWidthOptions}"
                                              SelectedItem="{Binding SelectedTicketLineWidth}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Classes="label" Text="Tipo de fuente (T. Carta):" />
                            <ComboBox ItemsSource="{Binding FontFamilyOptions}"
                                      SelectedItem="{Binding SelectedFontFamily}" />
                        </StackPanel>
                    </StackPanel>
                </Border>


            </StackPanel>
        </ScrollViewer>

        <!-- ===== FOOTER ===== -->
        <Border Grid.Row="2" Background="#252525" Padding="20,16" Margin="0,0,0,0">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*">
                <!-- Status Message -->
                <Border Grid.Row="0" 
                        Background="#1A3A1A"
                        Padding="12,8"
                        CornerRadius="6"
                        Margin="0,0,0,10"
                        BorderBrush="#4CAF50"
                        BorderThickness="1"
                        IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="✓" 
                                   FontSize="16" 
                                   Foreground="#4CAF50"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="#81C784"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Botones -->
                <StackPanel Grid.Row="1" 
                           Orientation="Horizontal" 
                           HorizontalAlignment="Right"
                           Spacing="12">
                    <Button Content="Cancelar (Esc)"
                            Command="{Binding CloseCommand}"
                            Classes="cancel"
                            Width="140" 
                            Height="42"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />

                    <Button Content="Guardar Cambios"
                            Command="{Binding SaveCommand}"
                            Classes="save"
                            Width="160" 
                            Height="42"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
