<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CasaCejaRemake.Views.Shared.AppDialog"
        Title="Mensaje"
        Width="440"
        Height="250"
        MinWidth="340"
        MinHeight="210"
        MaxWidth="560"
        MaxHeight="520"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Border Background="#1E1E1E"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Grid RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0"
                    Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="0,0,0,1"
                    Padding="22,16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border x:Name="AccentBorder"
                            Width="4"
                            Height="24"
                            CornerRadius="2"
                            Background="#1976D2"/>
                    <TextBlock x:Name="TitleText"
                               Text="Mensaje"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,22" Spacing="12">
                    <TextBlock x:Name="MessageText"
                               Text="Contenido del mensaje"
                               Foreground="#E0E0E0"
                               FontSize="14"
                               LineHeight="21"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="ShortcutText"
                               Text="Enter: Aceptar   |   Esc: Cerrar"
                               Foreground="#777777"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="0,1,0,0"
                    Padding="18,14">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button x:Name="CancelButton"
                            Content="Cancelar (Esc)"
                            MinWidth="125"
                            Padding="14,8"
                            Background="#424242"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            Click="OnCancelClick"/>
                    <Button x:Name="ConfirmButton"
                            Content="Aceptar (Enter)"
                            MinWidth="125"
                            Padding="14,8"
                            Background="#1976D2"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            FontWeight="SemiBold"
                            Click="OnConfirmClick"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
