<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Shared"
        xmlns:helpers="using:CasaCejaRemake.Helpers"
        x:Class="CasaCejaRemake.Views.Shared.HistoryView"
        x:DataType="vm:HistoryViewModel"
        x:CompileBindings="False"
        Title="Historial de Movimientos"
        WindowState="Maximized"
        Background="#141414">

    <Window.Resources>
        <helpers:BoolToColorConverter x:Key="BoolToColor"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="#2A2A2A"/>
        </Style>
        <Style Selector="Button.filter-btn">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.filter-btn:pointerover">
            <Setter Property="Background" Value="#388E3C"/>
        </Style>
        <Style Selector="Button.page-btn">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.page-btn:pointerover">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Button.page-btn:disabled">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2E2E2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2A2A"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="RowHeight" Value="36"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Padding="20,10">
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Classes="nav" Command="{Binding GoBackCommand}" ToolTip.Tip="Volver (Esc)">
                        <TextBlock Text="←" FontSize="15" Foreground="#2E7D32" FontWeight="Bold"/>
                    </Button>
                    <Border Width="4" Height="18" CornerRadius="2" Background="#2E7D32"/>
                    <TextBlock Text="HISTORIAL DE MOVIMIENTOS" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ FILTERS ═══ -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="20,8" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Filter controls -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <!-- Selector de sucursal - solo visible en modo Admin -->
                    <StackPanel Spacing="4" IsVisible="{Binding IsAdminMode}">
                        <TextBlock Text="SUCURSAL" FontSize="10" FontWeight="Bold"
                                   Foreground="#666" LetterSpacing="1"/>
                        <ComboBox ItemsSource="{Binding AvailableBranches}"
                                  SelectedItem="{Binding SelectedBranch}"
                                  Width="200"
                                  DisplayMemberBinding="{Binding Name}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="TIPO" FontSize="10" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                        <ComboBox SelectedIndex="{Binding SelectedFilterIndex}" Width="130">
                            <ComboBoxItem>Todos</ComboBoxItem>
                            <ComboBoxItem>Entradas</ComboBoxItem>
                            <ComboBoxItem>Salidas</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="DESDE" FontSize="10" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Width="140"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="HASTA" FontSize="10" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Width="140"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text=" " FontSize="10"/>
                        <Button Classes="filter-btn"
                                Command="{Binding SearchCommand}"
                                ToolTip.Tip="Filtrar (F5)">
                            Filtrar (F5)
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text=" " FontSize="10"/>
                        <Button Classes="page-btn"
                                Command="{Binding ClearFiltersCommand}"
                                ToolTip.Tip="Limpiar filtros (F6)">
                            Limpiar (F6)
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text=" " FontSize="10"/>
                        <Button Classes="page-btn"
                                Command="{Binding RefreshCommand}"
                                ToolTip.Tip="Actualizar desde servidor (F7)">
                            ↻ F7
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="4" IsVisible="{Binding IsSearching}">
                        <TextBlock Text=" " FontSize="10"/>
                        <TextBlock Text="Cargando registros" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#A5D6A7" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Stats badges — compact -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border CornerRadius="4" Padding="10,5" Background="#0A2A0A">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="↑" FontSize="11" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                            <TextBlock Text="ENTRADAS" FontSize="10" FontWeight="Bold" Foreground="#A5D6A7" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalEntries}" FontSize="13" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="4" Padding="10,5" Background="#2A0A0A">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="↓" FontSize="11" FontWeight="Bold" Foreground="#EF5350" VerticalAlignment="Center"/>
                            <TextBlock Text="SALIDAS" FontSize="10" FontWeight="Bold" Foreground="#EF9A9A" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalOutputs}" FontSize="13" FontWeight="Bold" Foreground="#EF5350" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ COLUMN HEADERS HINT ═══ -->
        <Border Grid.Row="2" Background="#161616" Padding="24,6" BorderBrush="#222" BorderThickness="0,0,0,1">
            <TextBlock Text="Haz doble clic o presiona Enter sobre un movimiento para ver el detalle completo"
                       FontSize="11" Foreground="#444" FontStyle="Italic"/>
        </Border>

        <!-- BANNER OFFLINE -->
        <Border Grid.Row="3"
                IsVisible="{Binding IsOffline}"
                Background="#3A2A00" BorderBrush="#FFA000"
                BorderThickness="0,0,0,1" Padding="20,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚠" Foreground="#FFB300" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OfflineMessage}"
                           Foreground="#FFB300" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ═══ DATA GRID ═══ -->
        <Grid Grid.Row="4">
            <DataGrid x:Name="HistoryDataGrid"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True"
                      CanUserSortColumns="True"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      Margin="0">
                <DataGrid.Columns>

                <!-- Fecha -->
                <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="160"/>

                <!-- Tipo — badge de color -->
                <DataGridTemplateColumn Header="TIPO" Width="120" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border VerticalAlignment="Center" HorizontalAlignment="Left"
                                    CornerRadius="4" Padding="10,3" Margin="14,0"
                                    Background="{Binding IsEntry, Converter={StaticResource BoolToColor}, ConverterParameter='#1B5E20|#7F1D1D'}">
                                <TextBlock Text="{Binding Tipo}"
                                           FontSize="11" FontWeight="Bold"
                                           Foreground="{Binding IsEntry, Converter={StaticResource BoolToColor}, ConverterParameter='#A5D6A7|#EF9A9A'}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Folio -->
                <DataGridTextColumn Header="FOLIO" Binding="{Binding Folio}" Width="210"/>

                <!-- Origen / Destino -->
                <DataGridTextColumn Header="ORIGEN / DESTINO" Binding="{Binding DestinoOrigen}" Width="*"/>

                <!-- Total -->
                <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat={}{0:C}}" Width="130"/>

                <!-- Estado -->
                <DataGridTemplateColumn Header="ESTADO" Width="130" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border VerticalAlignment="Center" HorizontalAlignment="Left"
                                    CornerRadius="4" Padding="10,3" Margin="14,0"
                                    Background="#1E2A3A">
                                <TextBlock Text="{Binding Estado}" FontSize="11" FontWeight="Bold" Foreground="#90CAF9"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#142A18"
                    BorderBrush="#2E7D32"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18,12"
                    IsVisible="{Binding IsSearching}">
                <StackPanel Width="260" Spacing="10">
                    <TextBlock Text="Cargando registros"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="6"
                                 Foreground="#2E7D32"
                                 Background="#1F3A24"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ FOOTER / PAGINATION ═══ -->
        <Border Grid.Row="5" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid ColumnDefinitions="*,Auto,*">

                <!-- Left: hint -->
                <TextBlock Grid.Column="0" Text="Enter: Ver detalle   |   Esc: Volver"
                           Foreground="#555" FontSize="12" VerticalAlignment="Center"/>

                <!-- Center: pagination -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" VerticalAlignment="Center">
                    <Button Classes="page-btn"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}">
                        ← Anterior
                    </Button>
                    <Border Background="#252525" CornerRadius="5" Padding="16,7">
                        <TextBlock Text="{Binding PaginationInfo}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <Button Classes="page-btn"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}">
                        Siguiente →
                    </Button>
                </StackPanel>

                <!-- Right: loading + export button -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                            Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="ExportButton"
                            Background="#1A2A1A"
                            Foreground="#4CAF50"
                            BorderBrush="#2E7D32"
                            BorderThickness="1"
                            Padding="14,7"
                            CornerRadius="5"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            ToolTip.Tip="Generar Excel (F8)">
                        ⬇  Generar Excel (F8)
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Window>
