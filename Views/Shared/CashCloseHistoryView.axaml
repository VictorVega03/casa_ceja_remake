<!-- CashCloseHistoryView.axaml -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Shared"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="CasaCejaRemake.Views.Shared.CashCloseHistoryView"
        x:DataType="vm:CashCloseHistoryViewModel"
        Title="Historial de Cortes de Caja"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Focusable="True"
        Background="#1E1E1E">

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="#3A3A3A"/>
        </Style>
        <Style Selector="Button.filter">
            <Setter Property="Background" Value="#1565C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.filter:pointerover">
            <Setter Property="Background" Value="#1976D2"/>
        </Style>
        <Style Selector="Button.page-btn">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.page-btn:pointerover">
            <Setter Property="Background" Value="#383838"/>
        </Style>
        <Style Selector="Button.page-btn:disabled">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#444"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="RowBackground" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3D3D3D"/>
        </Style>
        <Style Selector="DataGridRow:nth-child(2n) /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#252525"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#0D47A1"/>
        </Style>
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Padding="20,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Classes="nav" Command="{Binding CloseCommand}" ToolTip.Tip="Volver (Esc)">
                        <TextBlock Text="←" FontSize="15" Foreground="#1565C0" FontWeight="Bold"/>
                    </Button>
                    <Border Width="4" Height="18" CornerRadius="2" Background="#1565C0"/>
                    <TextBlock Text="HISTORIAL DE CORTES DE CAJA"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Total: " Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCount}" 
                               Foreground="#90CAF9" 
                               FontWeight="Bold"
                               FontSize="16"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="#1A1A1A" Padding="20,8" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <StackPanel Spacing="4" IsVisible="{Binding IsAdminMode}">
                        <TextBlock Text="SUCURSAL" FontSize="10" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                        <ComboBox ItemsSource="{Binding AvailableBranches}"
                                  SelectedItem="{Binding SelectedBranch}"
                                  Width="200"
                                  DisplayMemberBinding="{Binding Name}"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="BUSCAR" FontSize="10" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                        <TextBox x:Name="SearchTextBox"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 Watermark="Folio, usuario o sucursal"
                                 Width="240"
                                 Padding="8,6"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="DESDE" FontSize="10" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                        <DatePicker SelectedDate="{Binding FilterDateFrom}" Width="140"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="HASTA" FontSize="10" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                        <DatePicker SelectedDate="{Binding FilterDateTo}" Width="140"/>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text=" " FontSize="10"/>
                        <Button Command="{Binding ApplyDateFilterCommand}"
                                Classes="filter"
                                ToolTip.Tip="Filtrar (F5)">
                            Filtrar (F5)
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text=" " FontSize="10"/>
                        <Button Command="{Binding ClearFiltersCommand}"
                                Classes="page-btn"
                                ToolTip.Tip="Limpiar filtros (F6)">
                            Limpiar (F6)
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text=" " FontSize="10"/>
                        <Button Command="{Binding RefreshCommand}"
                                Classes="page-btn"
                                ToolTip.Tip="Actualizar desde servidor (F7)">
                            ↻ F7
                        </Button>
                    </StackPanel>
                    <StackPanel Spacing="4" IsVisible="{Binding IsLoading}">
                        <TextBlock Text=" " FontSize="10"/>
                        <TextBlock Text="Cargando cortes" FontSize="12" FontWeight="SemiBold"
                                   Foreground="#90CAF9" VerticalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Hint -->
        <Border Grid.Row="2" Background="#161616" Padding="24,6" BorderBrush="#222" BorderThickness="0,0,0,1">
            <TextBlock Text="Haz doble clic o presiona Enter sobre un corte para ver el detalle completo"
                       FontSize="11" Foreground="#444" FontStyle="Italic"/>
        </Border>

        <!-- BANNER OFFLINE -->
        <Border Grid.Row="3"
                IsVisible="{Binding IsOffline}"
                Background="#3A2A00" BorderBrush="#FFA000"
                BorderThickness="0,0,0,1" Padding="20,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⚠" Foreground="#FFB300" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OfflineMessage}"
                           Foreground="#FFB300" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Grid Grid.Row="4">
            <DataGrid x:Name="DataGridItems"
                      ItemsSource="{Binding Items}"
                      SelectedItem="{ReflectionBinding SelectedItem, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="10"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="FOLIO" Binding="{Binding Folio}" Width="260"/>
                    <DataGridTextColumn Header="USUARIO" Binding="{Binding UserName}" Width="180"/>
                    <DataGridTextColumn Header="SUCURSAL" Binding="{Binding BranchName}" Width="180"/>
                    <DataGridTextColumn Header="FECHA CIERRE" Binding="{Binding CloseDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="160"/>
                    <DataGridTextColumn Header="FONDO" Binding="{Binding OpeningCash, StringFormat='{}{0:C2}'}" Width="130"/>
                    <DataGridTextColumn Header="TOTAL CORTE" Binding="{Binding TotalDelCorte, StringFormat='{}{0:C2}'}" Width="140"/>
                    <DataGridTextColumn Header="ESPERADO" Binding="{Binding ExpectedCash, StringFormat='{}{0:C2}'}" Width="130"/>
                    <DataGridTextColumn Header="DIFERENCIA" Binding="{Binding Surplus, StringFormat='{}{0:C2}'}" Width="130"/>
                    <DataGridTextColumn Header="RESULTADO" Binding="{Binding SurplusStatus}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#10233A"
                    BorderBrush="#1565C0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="18,14"
                    IsVisible="{Binding IsLoading}">
                <StackPanel Width="260" Spacing="10">
                    <TextBlock Text="Cargando cortes..."
                               Foreground="#90CAF9"
                               FontWeight="Bold"
                               FontSize="15"
                               HorizontalAlignment="Center"/>
                    <ProgressBar IsIndeterminate="True"
                                 Height="6"
                                 Foreground="#1565C0"
                                 Background="#1B2B44"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer / Pagination -->
        <Border Grid.Row="5" Background="#1E1E1E" BorderBrush="#2A2A2A" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid ColumnDefinitions="*,Auto,*">
                <TextBlock Grid.Column="0" Text="Enter: Ver detalle   |   Esc: Volver"
                           Foreground="#555" FontSize="12" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" VerticalAlignment="Center">
                    <Button Classes="page-btn"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoPrevious}">
                        ← Anterior
                    </Button>
                    <Border Background="#252525" CornerRadius="5" Padding="16,7">
                        <TextBlock Text="{Binding PaginationInfo}" Foreground="White" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <Button Classes="page-btn"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoNext}">
                        Siguiente →
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                            Spacing="12" VerticalAlignment="Center">
                    <Button Command="{Binding ExportToExcelCommand}"
                            Background="#1A2A1A"
                            Foreground="#4CAF50"
                            BorderBrush="#2E7D32"
                            BorderThickness="1"
                            Padding="14,7"
                            CornerRadius="5"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            ToolTip.Tip="Generar Excel (F8)">
                        ⬇  Generar Excel (F8)
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
