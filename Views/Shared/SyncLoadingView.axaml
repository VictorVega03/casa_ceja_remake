<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CasaCejaRemake.ViewModels.Shared"
        x:Class="CasaCejaRemake.Views.Shared.SyncLoadingView"
        x:DataType="vm:SyncLoadingViewModel"
        Title="Casa Ceja"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="#1A1A2E">

    <Grid RowDefinitions="*,Auto,Auto,Auto,*" Margin="40">

        <!-- Logo del negocio (con relieve visual) -->
        <Grid Grid.Row="1"
              Width="148"
              Height="148"
              HorizontalAlignment="Center">

            <!-- Halo exterior -->
            <Border Width="148"
                Height="148"
                CornerRadius="74"
                Background="#101427"
                Opacity="0.65" />

            <!-- Anillo medio -->
            <Border Width="132"
                Height="132"
                CornerRadius="66"
                Background="#252B45"
                BorderBrush="#3A446E"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />

            <!-- Marco interno tipo sticker -->
            <Border Width="116"
                Height="116"
                CornerRadius="58"
                Background="#1F243B"
                BorderBrush="#E53935"
                BorderThickness="0.8"
                Padding="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border CornerRadius="48"
                ClipToBounds="True"
                Background="#1F243B">
                <Image Source="/Assets/LogoCasaCeja.png"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapInterpolationMode="HighQuality" />
            </Border>
            </Border>
        </Grid>

        <!-- Nombre del sistema -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0" HorizontalAlignment="Center" Spacing="4">
            <TextBlock Text="CASA CEJA"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       LetterSpacing="6" />
            <TextBlock Text="Sistema de Gestión Integral"
                       FontSize="10"
                       Foreground="#666666"
                       HorizontalAlignment="Center"
                       LetterSpacing="1.2" />
        </StackPanel>

        <!-- Estado de sincronización -->
        <StackPanel Grid.Row="3" Margin="0,24,0,0" Spacing="10">
            <ProgressBar IsIndeterminate="{Binding IsSyncing}"
                         IsVisible="{Binding IsSyncing}"
                         Height="3"
                         Background="#2A2A3E"
                         Foreground="#2196F3" />
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11"
                       Foreground="#888888"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </StackPanel>

    </Grid>
</Window>