<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CasaCejaRemake.Views.Shared.ModuleExitDialog"
        Title="Confirmar salida"
        Width="440"
        Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Border Background="#1E1E1E"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="8">
        <Grid RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0"
                    Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="0,0,0,1"
                    Padding="22,16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border x:Name="AccentBorder"
                            Width="4"
                            Height="24"
                            CornerRadius="2"
                            Background="#C62828"/>
                    <TextBlock x:Name="TitleText"
                               Text="Salir del módulo"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Margin="24,22"
                        Spacing="10">
                <TextBlock x:Name="MessageText"
                           Text="¿Está seguro de salir?"
                           Foreground="#E0E0E0"
                           FontSize="14"
                           TextWrapping="Wrap"/>
                <TextBlock x:Name="ShortcutText"
                           Text="Enter: Confirmar   |   Esc: Cancelar"
                           Foreground="#777777"
                           FontSize="11"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="0,1,0,0"
                    Padding="18,14">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button x:Name="CancelButton"
                            Content="Cancelar (Esc)"
                            Width="135"
                            Padding="14,8"
                            Background="#424242"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            Click="OnCancelClick"/>
                    <Button x:Name="ExitButton"
                            Content="Confirmar (Enter)"
                            Width="135"
                            Padding="14,8"
                            Background="#C62828"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            FontWeight="SemiBold"
                            Click="OnExitClick"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
