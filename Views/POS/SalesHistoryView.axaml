<!-- SalesHistoryView.axaml -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CasaCejaRemake.ViewModels.POS"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
        x:Class="CasaCejaRemake.Views.POS.SalesHistoryView"
        x:DataType="vm:SalesHistoryViewModel"
        Title="Historial de Operaciones"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Focusable="True"
        Background="#1E1E1E">

    <Window.Styles>
        <Style Selector="Button.filter">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        <Style Selector="Button.filter:pointerover">
            <Setter Property="Background" Value="#4D4D4D"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="#66BB6A"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
        <Style Selector="Button.secondary:pointerover">
            <Setter Property="Background" Value="#1084D8"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="RowBackground" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3D3D3D"/>
        </Style>
        <Style Selector="DataGridRow:nth-child(2n) /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#252525"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
            <Setter Property="Fill" Value="#4CAF50"/>
        </Style>
        <Style Selector="CalendarDatePicker">
            <Setter Property="Background" Value="#3D3D3D"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="15">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="HISTORIAL DE OPERACIONES"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Total: " Foreground="#AAAAAA" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalCount}" 
                               Foreground="#4CAF50" 
                               FontWeight="Bold"
                               FontSize="16"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="#252525" Padding="10">
            <Grid RowDefinitions="Auto,Auto">
                <!-- Search and Date Filters -->
                <Border Grid.Row="0" 
                        Background="#2D2D2D" 
                        CornerRadius="5" 
                        Padding="10"
                        Margin="0,0,0,10">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="Buscar Folio:" 
                                   Foreground="#AAAAAA" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox x:Name="SearchTextBox"
                                 Grid.Column="1"
                                 Text="{Binding SearchText, Mode=TwoWay}"
                                 Watermark="Ingrese folio de venta..."
                                 Background="#3D3D3D"
                                 Foreground="White"
                                 BorderBrush="#555555"
                                 Padding="8,6"
                                 Margin="0,0,15,0"/>
                        
                        <!-- Date Filters -->
                        <TextBlock Grid.Column="2"
                                   Text="Desde:" 
                                   Foreground="#AAAAAA" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>
                        <CalendarDatePicker Grid.Column="3"
                                            SelectedDate="{Binding FilterDateFrom}"
                                            SelectedDateFormat="Short"
                                            Background="#3D3D3D"
                                            Foreground="White"
                                            Margin="0,0,10,0"/>
                        
                        <TextBlock Grid.Column="4"
                                   Text="Hasta:" 
                                   Foreground="#AAAAAA" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>
                        <CalendarDatePicker Grid.Column="5"
                                            SelectedDate="{Binding FilterDateTo}"
                                            SelectedDateFormat="Short"
                                            Background="#3D3D3D"
                                            Foreground="White"
                                            Margin="0,0,10,0"/>
                        
                        <Button Grid.Column="6"
                                Content="Aplicar Filtros (F5)"
                                Command="{Binding ApplyFiltersCommand}"
                                Classes="filter"
                                Background="#0078D4"/>
                    </Grid>
                </Border>
                
                <!-- Quick Actions -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Acciones:"
                                   Foreground="#AAAAAA"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <Button Content="F3 Ventas del Corte"
                                Command="{Binding ShowCorteCommand}"
                                IsVisible="{Binding HasCashCloseFilter}"
                                Classes="filter"
                                Background="#1565C0"
                                Foreground="White"/>
                        <Button Content="F4 Mostrar Todas"
                                Command="{Binding ShowAllCommand}"
                                Classes="filter"
                                Background="#4CAF50"
                                Foreground="White"/>
                        <Button Content="F6 Limpiar"
                                Command="{Binding ClearFiltersCommand}"
                                Classes="filter"/>
                        <Button Content="F7 Buscar"
                                Command="{Binding ExecuteSearchCommand}"
                                Classes="filter"
                                Background="#FF9800"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- TabControl: Ventas | Créditos | Apartados -->
        <TabControl Grid.Row="2" Margin="10,5,10,0">

            <!-- TAB: VENTAS -->
            <TabItem Header="Ventas">
                <Grid>
                    <!-- Estado vacío -->
                    <Border Grid.Row="0"
                            IsVisible="{Binding ShowEmptyState}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="Sin ventas para mostrar"
                                       Foreground="#888888"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Aplique filtros de fecha o haga clic en 'Mostrar Todas'"
                                       Foreground="#555555"
                                       FontSize="14"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid de ventas -->
                    <DataGrid x:Name="DataGridItems"
                              Grid.Row="0"
                              ItemsSource="{Binding Items}"
                              SelectedItem="{ReflectionBinding SelectedItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              IsVisible="{Binding !ShowEmptyState}"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FOLIO" Binding="{Binding Folio}" Width="180"/>
                            <DataGridTextColumn Header="FECHA/HORA" Binding="{Binding FormattedDate}" Width="160"/>
                            <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat='{}{0:C2}'}" Width="130"/>
                            <DataGridTextColumn Header="DESCUENTO" Binding="{Binding Discount, StringFormat='{}{0:C2}'}" Width="120"/>
                            <DataGridTextColumn Header="USUARIO" Binding="{Binding UserName}" Width="180"/>
                            <DataGridTextColumn Header="FOLIO CORTE" Binding="{Binding CashCloseFolio}" Width="160"/>
                            <DataGridTextColumn Header="MÉTODO DE PAGO" Binding="{Binding PaymentSummary}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </TabItem>

            <!-- TAB: CRÉDITOS -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Créditos" VerticalAlignment="Center"/>
                        <Border CornerRadius="8" Padding="5,1" Background="#1565C0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CreditsCount}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <DataGrid x:Name="CreditsGrid"
                          ItemsSource="{Binding Credits}"
                          SelectedItem="{Binding SelectedCredit, Mode=TwoWay}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          DoubleTapped="CreditsGrid_DoubleTapped">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FOLIO"    Binding="{Binding Folio}"                                        Width="160"/>
                        <DataGridTextColumn Header="TOTAL"    Binding="{Binding Total, StringFormat='{}{0:C2}'}"               Width="120"/>
                        <DataGridTextColumn Header="PAGADO"   Binding="{Binding TotalPaid, StringFormat='{}{0:C2}'}"           Width="120"/>
                        <DataGridTextColumn Header="SALDO"    Binding="{Binding RemainingBalance, StringFormat='{}{0:C2}'}"    Width="120"/>
                        <DataGridTextColumn Header="ESTADO"   Binding="{Binding StatusName}"                                   Width="120"/>
                        <DataGridTextColumn Header="FECHA"    Binding="{Binding CreditDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <!-- TAB: APARTADOS -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Apartados" VerticalAlignment="Center"/>
                        <Border CornerRadius="8" Padding="5,1" Background="#E65100" VerticalAlignment="Center">
                            <TextBlock Text="{Binding LayawaysCount}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </TabItem.Header>
                <DataGrid x:Name="LayawaysGrid"
                          ItemsSource="{Binding Layaways}"
                          SelectedItem="{Binding SelectedLayaway, Mode=TwoWay}"
                          IsReadOnly="True"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          DoubleTapped="LayawaysGrid_DoubleTapped">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FOLIO"    Binding="{Binding Folio}"                                          Width="160"/>
                        <DataGridTextColumn Header="TOTAL"    Binding="{Binding Total, StringFormat='{}{0:C2}'}"                 Width="120"/>
                        <DataGridTextColumn Header="PAGADO"   Binding="{Binding TotalPaid, StringFormat='{}{0:C2}'}"             Width="120"/>
                        <DataGridTextColumn Header="SALDO"    Binding="{Binding RemainingBalance, StringFormat='{}{0:C2}'}"      Width="120"/>
                        <DataGridTextColumn Header="ESTADO"   Binding="{Binding StatusName}"                                     Width="120"/>
                        <DataGridTextColumn Header="FECHA"    Binding="{Binding LayawayDate, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>

        <!-- Bottom Buttons -->
        <Border Grid.Row="3"
                Background="#1E1E1E"
                BorderBrush="#2A2A2A"
                BorderThickness="0,1,0,0"
                Padding="20,10">
            <Grid ColumnDefinitions="*,Auto,*">
                <TextBlock Grid.Column="0"
                           Text="Esc: Volver"
                           Foreground="#555"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Button Content="← Anterior"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding CanGoBack}"
                            Classes="filter"/>
                    <Border Background="#252525" CornerRadius="5" Padding="16,7">
                        <TextBlock VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold">
                            <Run Text="Página "/>
                            <Run Text="{Binding CurrentPage}"/>
                            <Run Text=" de "/>
                            <Run Text="{Binding TotalPages}"/>
                        </TextBlock>
                    </Border>
                    <Button Content="Siguiente →"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding CanGoForward}"
                            Classes="filter"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Button Command="{Binding ViewDetailCommand}"
                            Width="155"
                            MinHeight="34"
                            Background="#102A43"
                            Foreground="#64B5F6"
                            BorderBrush="#1976D2"
                            BorderThickness="1"
                            Padding="14,7"
                            CornerRadius="5"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            IsEnabled="{Binding HasSelectedItem}"
                            ToolTip.Tip="Ver detalle (Enter)">
                        Ver detalle (Enter)
                    </Button>
                    <Button Command="{Binding ExportToExcelCommand}"
                            Width="155"
                            MinHeight="34"
                            Background="#1A2A1A"
                            Foreground="#4CAF50"
                            BorderBrush="#2E7D32"
                            BorderThickness="1"
                            Padding="14,7"
                            CornerRadius="5"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            ToolTip.Tip="Generar Excel (F8)">
                        ⬇  Generar Excel (F8)
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="4"
                Background="#80000000"
                IsVisible="{Binding IsLoading}">
            <Border Background="#2D2D2D" 
                    Padding="30" 
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="15">
                    <ProgressBar IsIndeterminate="True" Width="200"/>
                    <TextBlock Text="Cargando..." 
                               Foreground="White" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
