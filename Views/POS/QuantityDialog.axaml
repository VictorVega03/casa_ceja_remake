<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CasaCejaRemake.Views.POS.QuantityDialog"
        Title="Modificar cantidad"
        Width="420"
        Height="270"
        MinWidth="340"
        MinHeight="240"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Border Background="#1E1E1E"
            BorderBrush="#3A3A3A"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Grid RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0"
                    Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="0,0,0,1"
                    Padding="22,16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Border Width="4"
                            Height="24"
                            CornerRadius="2"
                            Background="#EF6C00"/>
                    <TextBlock Text="Modificar cantidad"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1"
                        Margin="24,20"
                        Spacing="10">
                <TextBlock x:Name="ProductText"
                           Foreground="#E0E0E0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
                <TextBlock Text="CANTIDAD"
                           Foreground="#999999"
                           FontSize="11"
                           FontWeight="SemiBold"/>
                <NumericUpDown x:Name="QuantityInput"
                               Minimum="1"
                               Maximum="9999"
                               Increment="1"
                               FormatString="0"
                               Height="38"
                               HorizontalContentAlignment="Center"/>
                <TextBlock Text="Enter: Aplicar   |   Esc: Cancelar"
                           Foreground="#777777"
                           FontSize="11"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="#242424"
                    BorderBrush="#333333"
                    BorderThickness="0,1,0,0"
                    Padding="18,14">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="10">
                    <Button Content="Cancelar (Esc)"
                            MinWidth="125"
                            Padding="14,8"
                            Background="#424242"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            Click="OnCancelClick"/>
                    <Button Content="Aplicar (Enter)"
                            MinWidth="125"
                            Padding="14,8"
                            Background="#EF6C00"
                            Foreground="White"
                            BorderThickness="0"
                            CornerRadius="4"
                            FontWeight="SemiBold"
                            Click="OnApplyClick"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
