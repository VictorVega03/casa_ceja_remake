<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CasaCejaRemake.ViewModels.POS"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="560"
        x:Class="CasaCejaRemake.Views.POS.QuickCustomerView"
        x:DataType="vm:QuickCustomerViewModel"
        Title="Alta de Cliente"
        Width="620" MinWidth="480"
        Height="560" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ShowInTaskbar="False"
        Focusable="True"
        Background="#1E1E1E">

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3D3D3D"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
        </Style>
        <Style Selector="TextBlock.required">
            <Setter Property="Foreground" Value="#FF5252"/>
        </Style>
        <Style Selector="TextBlock.section">
            <Setter Property="Foreground" Value="#7E8CF7"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="15,12">
            <TextBlock Text="ALTA DE CLIENTE"
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" Padding="20,8,20,8"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">

                <!-- ── Datos generales ── -->
                <TextBlock Text="DATOS GENERALES" Classes="section"/>
                <Grid ColumnDefinitions="*,12,*">
                    <!-- Nombre -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Nombre" Classes="label"/>
                            <TextBlock Text=" *" Classes="label required"/>
                        </StackPanel>
                        <TextBox x:Name="NameBox"
                                 Text="{Binding Name}"
                                 Watermark="Nombre completo"/>
                    </StackPanel>
                    <!-- Teléfono -->
                    <StackPanel Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Teléfono" Classes="label"/>
                            <TextBlock Text=" *" Classes="label required"/>
                        </StackPanel>
                        <TextBox Text="{Binding Phone}"
                                 Watermark="10 dígitos"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,12,*">
                    <!-- Email -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Email" Classes="label"/>
                        <TextBox Text="{Binding Email}"
                                 Watermark="correo@ejemplo.com"/>
                    </StackPanel>
                    <!-- RFC -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="RFC" Classes="label"/>
                        <TextBox Text="{Binding Rfc}"
                                 MaxLength="13"
                                 Watermark="RFC (opcional)"/>
                    </StackPanel>
                </Grid>

                <!-- ── Dirección ── -->
                <TextBlock Text="DIRECCIÓN" Classes="section"/>
                <Grid ColumnDefinitions="*,12,80,12,80">
                    <!-- Calle -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Calle" Classes="label"/>
                        <TextBox Text="{Binding Street}"
                                 Watermark="Nombre de la calle"/>
                    </StackPanel>
                    <!-- No. Exterior -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="No. Ext." Classes="label"/>
                        <TextBox Text="{Binding ExteriorNumber}"
                                 MaxLength="20"
                                 Watermark="100"/>
                    </StackPanel>
                    <!-- No. Interior -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="No. Int." Classes="label"/>
                        <TextBox Text="{Binding InteriorNumber}"
                                 MaxLength="20"
                                 Watermark="A"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*,12,120">
                    <!-- Colonia -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Colonia" Classes="label"/>
                        <TextBox Text="{Binding Neighborhood}"
                                 Watermark="Nombre de la colonia"/>
                    </StackPanel>
                    <!-- Código Postal -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="C.P." Classes="label"/>
                        <TextBox Text="{Binding PostalCode}"
                                 MaxLength="10"
                                 Watermark="00000"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,4">
                    <TextBlock Text="Ciudad" Classes="label"/>
                    <TextBox Text="{Binding City}"
                             Watermark="Ciudad o municipio"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Error -->
        <Border Grid.Row="2"
                Margin="20,4"
                IsVisible="{Binding HasError}"
                Background="#FF5252"
                CornerRadius="4"
                Padding="10,8">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="White"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Botones -->
        <Border Grid.Row="3" Background="#2D2D2D" Padding="15,10">
            <Grid ColumnDefinitions="*,*">
                <Button Grid.Column="0"
                        Command="{Binding SaveCommand}"
                        Background="#4CAF50"
                        Foreground="White"
                        Padding="20,9"
                        HorizontalAlignment="Center"
                        IsEnabled="{Binding !IsSaving}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="F5"/>
                        <TextBlock Text="Guardar"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1"
                        Content="Cancelar (Esc)"
                        Command="{Binding CancelCommand}"
                        Background="#555555"
                        Foreground="White"
                        Padding="20,9"
                        HorizontalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
